# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat id (where orders/chats/visits get sent)
TELEGRAM_ADMIN_CHAT_ID=

# Upstash Redis (free tier works fine) - used to store orders + chat threads
# Get these from vercel.com -> Storage -> Create Database -> Upstash Redis
# or directly from upstash.com
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Password to log into /admin and manage products
ADMIN_PASSWORD=

# Cloudinary (console.cloudinary.com) - used for product photo uploads
# These are safe to expose to the browser (NEXT_PUBLIC_), the upload preset
# below must be set to "Unsigned" mode in Cloudinary's settings.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
